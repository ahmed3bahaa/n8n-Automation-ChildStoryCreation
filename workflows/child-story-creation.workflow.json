                                                          "values":  [
                                                                         {
                                                                             "content":  "=You are a children story writer. Write exactly five scenes according to the parsed input: {{ $json.message.content }}. Each scene must be between 3 and 5 sentences long. Prefix each scene with \"Scene 1:\", \"Scene 2:\", etc.",
                                                                             "role":  "system"
