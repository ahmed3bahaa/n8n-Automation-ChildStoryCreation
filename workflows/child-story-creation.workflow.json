                      "parameters":  {
                                         "jsCode":  "const story = $input.first().json.message.content\nconst scenes = story.split(/Scene\\s\\d+:/g).filter(s =\u003e s.trim() !== \"\");\n\nreturn scenes.map((scene, index) =\u003e {\n  return {\n    json: {\n      sceneNumber: index + 1,\n      text: scene.trim()\n    }\n  };\n});\n"
                                     },
