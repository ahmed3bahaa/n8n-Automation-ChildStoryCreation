                  {
                      "parameters":  {
                                         "jsCode":  "const scenes = $items(\"scene split\", 0, 0);\nconst images = $items(\"binary-json\");\n\nconst output = scenes.map((scene, idx) =\u003e ({\n  json: {\n    sceneNumber: scene.json.sceneNumber ?? idx + 1,\n    text: scene.json.text,\n   imageBase64: images[idx]?.json?.image \n                || images[idx]?.binary?.image?.data\n                || null, \n  }\n}));\n\nreturn output;\n"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       212,
                                       -860
                                   ],
                      "id":  "6fa830f1-ebb6-4b6b-9881-f499fd1119c1",
                      "name":  "Scene-image-align"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// pull in every scene/item\nconst scenes = $input.all();  \n\n// start your document\nlet html = `\u003c!DOCTYPE html\u003e\n\u003chtml\u003e\n  \u003chead\u003e\n    \u003cmeta charset=\"UTF-8\"\u003e\n    \u003ctitle\u003eStory Scenes\u003c/title\u003e\n    \u003cstyle\u003e\n      body { font-family: Arial, sans-serif; margin: 20px; }\n      .scene-card {\n        border: 1px solid #ddd;\n        border-radius: 8px;\n        padding: 20px;\n        margin-bottom: 40px;\n        box-shadow: 2px 2px 12px rgba(0,0,0,0.1);\n        /* force each card to start on a new PDF page */\n        page-break-after: always;\n      }\n      .scene-image img {\n        max-width: 100%;\n        height: auto;\n        border-radius: 8px;\n      }\n    \u003c/style\u003e\n  \u003c/head\u003e\n  \u003cbody\u003e\n`;\n\nscenes.forEach(scene =\u003e {\n  const { sceneNumber, text, imageBase64 } = scene.json;\n  html += `\n    \u003cdiv class=\"scene-card\"\u003e\n      \u003ch2\u003eScene ${sceneNumber}\u003c/h2\u003e\n      \u003cp\u003e${text}\u003c/p\u003e\n      ${ imageBase64\n         ? `\u003cdiv class=\"scene-image\"\u003e\n              \u003cimg src=\"data:image/png;base64,${imageBase64}\" alt=\"Scene ${sceneNumber}\"/\u003e\n            \u003c/div\u003e`\n         : ``\n      }\n    \u003c/div\u003e\n  `;\n});\n\nhtml += `\n  \u003c/body\u003e\n\u003c/html\u003e\n`;\n\n// return one big HTML\nreturn { html };\n"
                                     },
